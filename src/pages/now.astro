---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const enEntry = await getEntry('pages', 'now');
const zhEntry = await getEntry('pages', 'now.zh');
if (!enEntry) {
  throw new Error('Missing src/content/pages/now.md');
}
if (!zhEntry) {
  throw new Error('Missing src/content/pages/now.zh.md');
}
const { Content: EnContent } = await render(enEntry);
const { Content: ZhContent } = await render(zhEntry);
---

<BaseLayout title="现在 · 杨明天" description="杨明天最近在专注的事情。">
  <div class="lang-switch" role="tablist" aria-label="Language">
    <button type="button" class="lang-btn is-active" data-lang="zh" role="tab" aria-selected="true">中文</button>
    <button type="button" class="lang-btn" data-lang="en" role="tab" aria-selected="false">English</button>
  </div>

  <article id="now-zh" data-lang-content="zh">
    <ZhContent />
  </article>
  <article id="now-en" data-lang-content="en" hidden>
    <EnContent />
  </article>
</BaseLayout>

<style>
  .lang-switch {
    display: inline-flex;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
    padding: 0.25rem;
    border: 1px solid var(--rule);
    border-radius: 999px;
    background: color-mix(in srgb, var(--rule) 30%, transparent);
  }

  .lang-btn {
    appearance: none;
    border: none;
    background: transparent;
    color: var(--muted);
    font: inherit;
    font-size: 0.85rem;
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .lang-btn:hover {
    color: var(--fg);
  }

  .lang-btn.is-active {
    background: var(--bg);
    color: var(--fg);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.lang-btn');
  const articles = document.querySelectorAll<HTMLElement>('[data-lang-content]');

  function setLang(lang: string) {
    buttons.forEach((btn) => {
      const active = btn.dataset.lang === lang;
      btn.classList.toggle('is-active', active);
      btn.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    articles.forEach((article) => {
      const match = article.dataset.langContent === lang;
      article.hidden = !match;
    });
    try {
      localStorage.setItem('now-lang', lang);
    } catch {}
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const lang = btn.dataset.lang;
      if (lang) setLang(lang);
    });
  });

  try {
    const saved = localStorage.getItem('now-lang');
    if (saved === 'en' || saved === 'zh') {
      setLang(saved);
    }
  } catch {}
</script>
