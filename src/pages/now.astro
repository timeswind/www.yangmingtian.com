---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entry = await getEntry('pages', 'now');
if (!entry) {
  throw new Error('Missing src/content/pages/now.md');
}
const { Content } = await render(entry);
---

<BaseLayout title="Now · Yang Mingtian" description="What Yang Mingtian is currently focused on.">
  <article>
    <Content />
  </article>
</BaseLayout>
